# hantera inputs med try-exept
def säker_input(msg: str, error_msg:str, typ) -> str:
    try: 
        # inget felmeddelande uppstår 
        return typ(input(msg))
    
    # fuktionen används i många olika sammanhang och kräver att den fångar olika fel
    except (ValueError, NameError, SyntaxError): 
        print(error_msg)
        # funktionen kör sig själv för att skippa en while-loop 
        return säker_input(msg, error_msg, typ)

# tar input från användaren
def kort_input(antal_kort: int, num_kort: int, lista: list) -> None:
    # gör om klädda kort och färgerna till siffror
    klädda_kort_num = {"knekt": 11, "j": 11, "dam": 12, "q": 12, "kung": 13, "k": 13, "ess": 14, "a": 14}
    färg_check = ["s", "k", "h", "r"]

    for i in range(antal_kort): # antalet kort man ska dra
        while True: # while-loop för säkerhetsskäl
            try:
                # .lower() få allting i små bokstäver, stip() ta bort blanksteg (början och slut)
                färg, valör = input(f"kort {i + num_kort}: ").lower().strip().split()

                if valör in klädda_kort_num: # kolla om kortet är i dict
                    nya_valör = klädda_kort_num[valör]

                elif 1 < int(valör) < 15: # om valören anges som ett nummer 
                    nya_valör = int(valör)

                else: # annars ge felmeddelande 
                    print("Ange en giltig valör (2-14 eller 2-10 och knekt/dam/kung/ess\n")
                    continue # kör en iteration till om input inte är giltigt 

                # kolla om färgen är giltig 
                if färg[0] not in färg_check: 
                    # eftersom alla färger börjar på olika bokstäver räcker det att använda det
                    # + input går snabbare om man bara behöver skriva en bokstav
                    print("Ange en giltig färg (hjärter, spader, klöver, ruter)\n")
                    continue # kör en iteration till om input inte är giltigt 
                
                break

            except (ValueError):  # ValueError om inte split
                print("Fel format. Skriv t.ex. 'h 10' eller 'spader kung'.\n")

        tuple_kort = (färg, nya_valör)  # sparar kort som en tuple
        lista.append(tuple_kort) # NOTERA: ändrar lista utanför sin scope 

# säger vad spelaren ska göra
def spelare_beslut(win_chans: float, marker: int, pot:int, call: int) -> tuple:

    odds = call / (pot + call) # beräkna pot odds

    if call == 0: # först ut och inte har något att syna 
        if win_chans > 0.6: # om användaren har en stark hand 
            insats = int(pot*0.3) # höja med 0.3*pot för att anpassa efter pottens storlek 
            beslut_msg = f"RAISE ({insats})" 

        else: # annars checka 
            insats = 0 # kostar inget att checka
            beslut_msg = "CHECK"
            
    else: 
        if win_chans >= 0.6:
            insats = int(pot*0.3) + call # totala insats är höjningen + det man behöver syna 
            beslut_msg = f"RAISE ({insats})" 

        elif win_chans >= odds:
            insats = call # kostar att syna
            beslut_msg = "CALL"
        
        else:
            insats = 0 # kostar inget att folda
            beslut_msg = "FOLD"
    
    if insats >= marker: # kan inte satsa mer än vad man har tillängligt 
        beslut_msg = "ALL IN"

    stats = f"pot odds: {100 * odds:.2f}%  |  equity: {100 * win_chans:.2f}%" 
    return beslut_msg, insats, stats

# själva spelrundan
def spelrunda() -> None:
    # bara för att få igång while-loopen
    marker = 1

    # hela spelet - spelet görs så länge användaren har marker
    while marker > 0:

        # nollställs inför varje omgång (tycker namnen förklarar sig själva)
        hålkort = [] 
        community_cards = []
        pot = 0

        # key: vilken runda det är  value: antal kort man ska dra, numret på första kortet, listan som kortet ska sparas till
        runda_info = {"PRE-FLOP": (2, 1, hålkort), "FLOP": (3, 3, community_cards), "TURN": (1, 6, community_cards),"RIVER": (1, 7, community_cards)}

        # anger antalet marker innan spelet väl börjar
        while True:
            marker = säker_input(f"\n------------------------------------------\n\nmarker: ", f"Ange ett giltigt antal", eval)
            if marker:
                break
            else:
                # om man anger 0 marker
                print("\nDu kan inte spela med 0 marker") 

        for runda, info in runda_info.items(): # spelets fyra satsningsrundor 
            kort_antal, kort_num, kort_lista = info # info är en tuple 

            print(f"\n------------------------------------------\n\n{runda} - {marker} marker\n\n")

            # ange hur mycket man ska blinda 
            if runda == "PRE-FLOP": # bara på pre-flopen 
                marker -= säker_input(f"blind: ", f"Ange ett giltigt antal\n", int)
                print(" ")

            # anger korten man får
            kort_input(kort_antal, kort_num, kort_lista) 

            # en satningsrunda 
            while True: 
                print(f"\n------------------------------------------")

                # anger nödvändig information om spelet
                pot += säker_input(f"\npot: ", f"Ange ett giltigt antal", eval)
                call = säker_input(f"\natt syna: ", f"Ange ett giltigt antal", int)
                antal_spelare = säker_input(f"\nmotståndare: ", f"Ange ett giltigt antal\n", int)

                if not antal_spelare: # om alla foldat 
                    break
                
                # kör simuleringar och fattar ett beslut 
                res_sim = simulering(community_cards, hålkort, 20_000, antal_spelare)
                beslut, kostnad, stats_msg = spelare_beslut(res_sim, marker, pot, call)

                print(f"\n\n{beslut} - {stats_msg}\n")

                # alla möjliga utfall 
                if beslut == "ALL IN" or beslut == "FOLD": # satsningsrundan avslutas (ut ur den innersta while-loopen)
                    break

                elif beslut == "CALL" or beslut[:5] == "RAISE" or beslut == "CHECK": # fortsätter 
                    marker -= kostnad

                    # strip(), lower() för att se till att input blir ja/nej 
                    raise_check = säker_input("\nhöjde någon (ja/nej):","Svara med ja eller nej", str).strip().lower()
                    if raise_check != "ja": # om någon höjer fortsätter satsningsrundan
                        break               # annars avslutas den
            
            # satsningsrundan avslutas på riktigt (tillbaka till den yttersta while-loopen)
            if not antal_spelare or beslut == "FOLD":
                break
    
    print("\n------------------------------------------\n\nslut på marker\n\n------------------------------------------\n")


