for path in run_path.glob("*.run"):
    with path.open("r") as f:
        data = json.load(f)

    if data["ascension_level"] in asc_dict:
        asc_dict[data["ascension_level"]] += 1
    else:
        asc_dict[data["ascension_level"]] = 1

    for i in data["relics"]:
        if i in rel_dict:
            rel_dict[i] += 1
        else:
            rel_dict[i] = 1

    for i in data["master_deck"]:
        if i in deck_dict and i != "AscendersBane":
            deck_dict[i] += 1
        else:
            deck_dict[i] = 1

