def get_json(address):
    path = Path(address)
    
    with path.open("r") as f:
        data = json.load(f)
    
    return data


def set_json(file, stat):    
    
    if file[stat] is list:
        return file[stat]
    
    else:
        temp = []
        temp.append(file[stat])
        return temp

